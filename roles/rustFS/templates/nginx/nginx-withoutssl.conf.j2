# Upstream for S3 API (Port 9000)
upstream rustfs_api {
    # In 2026, 'keepalive' is essential for Rust async performance
    server 127.0.0.1:9000;
    keepalive 32;
}

# Upstream for Console UI (Port 9001)
upstream rustfs_console {
    server 127.0.0.1:9001;
}

server {
    listen 80;
    server_name {{ s3_domain | default('_') }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Standard S3 performance optimizations
    ignore_invalid_headers off;
    client_max_body_size 0;
    proxy_buffering off;
    proxy_request_buffering off;

    # Metadata for identification (Helpful for OTel)
    add_header X-RustFS-Node-Role "{{ rustfsmaster | ternary('master', 'slave') }}";

    # S3 API Location
    location / {
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 300;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        chunked_transfer_encoding off;

        proxy_pass http://rustfs_api;
    }

    # Health check passthrough
    location /minio/health/live {
        proxy_pass http://rustfs_api;
    }
}

server {
    listen 80;
    server_name {{ console_domain | default('console.local') }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support for the 2026 Console
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_pass http://rustfs_console;
    }
}