#! /usr/bin/env/ bash
## variables ###########################################
DATA_DIR=/var/lib/docker/volumes/gitlab_config/
BACKUP_DIR=/opt/BACKUP/
TIME=$(date "+%F_%H-%M-%S")
BACKUP_NAME=gitlab_config_backup_${TIME}
ENCRYPT_PASS={{ gitlab_backup_encryption_pass }}

S3_ENDPOINT={{ s3_api_endpoint }}
S3_USERNAME={{ s3_gitlab_backup_username }}
S3_PASSWORD={{ s3_gitlab_backup_password }}
S3_BUCKET={{ s3_gitlab_backup_config_bucket }}
S3_ALIAS=s3_gitlab_backup
########################################################

# create ${BACKUP_DIR} if not exist
[[ -d ${BACKUP_DIR} ]] || mkdir -p ${BACKUP_DIR}

# create and move backup file
cd ${DATA_DIR}
tar -czf ${BACKUP_NAME}.tar.gz _data/*
mv ${BACKUP_NAME}.tar.gz ${BACKUP_DIR}

# encrypt backup file
cd ${BACKUP_DIR}
gpg --symmetric \
    --cipher-algo AES256 \
    --batch --yes \
    --passphrase ${ENCRYPT_PASS} \
    ${BACKUP_NAME}.tar.gz

# change backup file attribute
chattr +i ${BACKUP_NAME}.tar.gz

# check and setup mc information
which mc || curl https://dl.min.io/client/mc/release/linux-amd64/mc \
                                        -o /usr/local/bin/mc \
                                        && chmod +x /usr/local/bin/mc

mc alias list | grep ${S3_ALIAS} || mc alias set ${S3_ALIAS} ${S3_ENDPOINT} ${S3_USERNAME} ${S3_PASSWORD}

cd ${BACKUP_DIR}
mc put ${BACKUP_NAME}.tar.gz.gpg ${S3_ALIAS}/${S3_BUCKET}
rm ${BACKUP_NAME}.tar.gz.gpg
mc ls ${S3_ALIAS}/${S3_BUCKET}/${BACKUP_NAME}.tar.gz.gpg