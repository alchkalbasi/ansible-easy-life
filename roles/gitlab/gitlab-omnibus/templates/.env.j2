# Global
PRIVATE_NETWORK={{ docker_network[0] }}
PUBLIC_NETWORK={{ docker_network[1] }}
RESTART_POLICY={{ restart_policy }}

# Gitlab Service
GITLAB_IMAGE_TAG={{ gitlab_image_tag }}
GITLAB_CONTAINER_NAME={{ gitlab_container_name }}
GITLAB_DOMAIN={{ gitlab_main_domain }}
# Gitlab Root Pass
GITLAB_ROOT_PASS={{ gitlab_root_password }}
# Gitlab Nginx
GITLAB_NGINX_MAX_BODY={{ gitlab_nginx_max_body_size }}
# Gitlab SMTP
SMTP_ADDRESS={{ smtp_address }}
SMTP_PORT={{ smtp_port }}
SMTP_USERNAME={{ smtp_username }}
SMTP_PASSWORD={{ smtp_password }}
SMTP_DOMAIN={{ smtp_domain }}
# Gitlab backup
GITLAB_BACKUP_KEEP_TIME={{ gitlab_backup_keep_time }}
# Gitlab S3
GITLAB_S3_ACCESS_KEY={{ gitlab_s3_access_key }}
GITLAB_S3_SECRET_KEY={{ gitlab_s3_secret_key }}
GITLAB_S3_ENDPOINT={{ gitlab_s3_endpoint }}
GITLAB_S3_BUCKET={{ gitlab_s3_bucket }}
# Gitlab Registery
REGISTRY_DOMAIN={{ gitlab_registry_domain }}
GITLAB_REG_MAX_BODY={{ gitlab_reg_max_body_size }}
GITLAB_REGISTERY_S3_BUCKET={{ gitlab_registery_s3_bucket }}