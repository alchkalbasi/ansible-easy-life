DOCKER_NETWORK_PRIVATE={{ docker_networks[0] }}
RESTART_POLICY={{ restart_policy }}

POSTGRES_SLAVE_VERSION={{ postgres_version | default('16') }}
POSTGRES_SLAVE_HOSTNAME={{ postgres_slave_hostname }}
POSTGRES_SLAVE_CONTAINER_NAME={{ postgres_slave_container_name }}
POSTGRES_SLAVE_PASSWORD={{ postgres_slave_password }}
POSTGRES_SLAVE_USER={{ postgres_slave_user }}
POSTGRES_SLAVE_PORT={{ postgres_slave_port | default(5432) }}

POSTGRES_EXPORTER_TAG={{ postgres_exporter_tag | default('latest') }}
POSTGRES_EXPORTER_HOSTNAME={{ postgres_exporter_hostname }}
POSTGRES_EXPORTER_CONTAINER_NAME={{ postgres_exporter_container_name }}
POSTGRES_EXPORTER_USER={{ postgres_exporter_user }}
POSTGRES_EXPORTER_PASSWORD={{ postgres_exporter_password }}
EXTEND_COLLECTORS={{ extend_collectors }}
DESABLE_COLLECTORS={{ disable_collectors }}
POSTGRES_EXPORTER_PORT={{ postgres_exporter_port | default('9187') }}