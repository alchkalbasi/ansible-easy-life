# Generated by ansible on {{ ansible_date_time.date }} by {{ author | default(ansible_user) }}
*filter

{% if enable_drop_input %}
:INPUT DROP
{% else %}
:INPUT ACCEPT
{% endif %}

{% if enable_drop_forward %}
:FORWARD DROP
{% else %}
:FORWARD ACCEPT
{% endif %}

{% if enable_drop_output %}
:OUTPUT DROP
{% else %}
:OUTPUT ACCEPT
{% endif %}

{% if enable_lo %}
-A INPUT -i lo -j ACCEPT
{% endif %}

{% if enable_conntrack %}
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
{% endif %}

{% if enable_http_port %}
-A INPUT -p tcp -m tcp --dport 80 -j ACCEPT
{% endif %}

{% if enable_https_port %}
-A INPUT -p tcp -m tcp --dport 443 -j ACCEPT
{% endif %}

{% if enable_ssh %}
-A INPUT -p tcp -m tcp --dport {{ ssh_port | default(22) }} -j ACCEPT
{% endif %}

{% if enable_icmp %}
-A INPUT -p icmp -j ACCEPT
{% endif %}

{% if enable_docker_forward %}
-A FORWARD -i docker0 -o docker0 -j ACCEPT
-A FORWARD -i docker0 ! -o docker0 -j ACCEPT
-A FORWARD -o docker0 -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
{% endif %}

COMMIT
